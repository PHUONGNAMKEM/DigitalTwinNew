# ==============================================
# Cấu hình môi trường Digital Twin System
# Copy file này thành .env và điều chỉnh các giá trị theo môi trường của bạn
# ==============================================

# MongoDB Atlas Configuration
# THAY ĐỔI connection string theo MongoDB Atlas cluster của bạn
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=DigitalTwinDB

# BaSyx Server Configuration
BASYX_SERVER_PORT=8081
BASYX_URL=http://localhost:8081

# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=dt/sensors

# Nginx Proxy
NGINX_PORT=8888

# AAS GUI Configuration
AAS_GUI_PORT=3001
AAS_GUI_PRIMARY_COLOR=#00A651

# Container Ports
MQTT_WS_PORT=9001

# Device Manager Web
DEVICE_MANAGER_PORT=5000
